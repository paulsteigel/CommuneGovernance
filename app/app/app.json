{
  "expo": {
    "name": "CommuneGovernance",
    "slug": "commune-governance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.care.communegovernance"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "org.care.communegovernance"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        { "backgroundColor": "#1B5E20", "image": "./assets/splash.png" }
      ]
    ],
    "scheme": "communegovernance",
    "experiments": {
      "typedRoutes": true
    }
  }
}
